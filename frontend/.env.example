# ──────────────────────────────────────────────────────────────────────────────
# NeuroGuardianFin — Frontend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# IMPORTANT: This file is in .gitignore and will NOT be committed to git.
#            Copy this to .env and fill in your real keys.
# ──────────────────────────────────────────────────────────────────────────────

# Gemini API (Google AI Studio) — https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API — https://platform.deepseek.com/api_keys
REACT_APP_DEEPSEEK_API_KEY=your_deepseek_api_key_here
