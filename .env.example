# ==============================================================================
# NEUROGUARDIAN ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Instructions:
# 1. Rename this file from '.env.example' to '.env'
# 2. Add your API keys below
# 3. Restart your Django server (backend keys)
# 4. For frontend keys, also create frontend/.env (see frontend/.env.example)
# ==============================================================================

# ── Django Backend Keys ────────────────────────────────────────────────────────

# 1. GOOGLE GEMINI API KEY (Django backend — AI Medical Reports)
# Get it free from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. GOOGLE PLACES API KEY (Nearby hospitals)
# Get it from Google Cloud Console (Enable Places API)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── React Frontend Keys (also add these to frontend/.env) ─────────────────────

# 3. GEMINI API KEY — used by chatbot (React)
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# 4. DEEPSEEK API KEY — chatbot fallback (React)
REACT_APP_DEEPSEEK_API_KEY=your_deepseek_api_key_here
